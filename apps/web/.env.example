# Copy to .env.local and fill in real values (apps/web/.env.local).
# Values come from your Supabase dashboard: Project Settings -> API Keys.

# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"

# Publishable key (sb_publishable_...). The legacy anon JWT also works.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_REPLACE_ME"

# Secret key (sb_secret_...) — server-only, bypasses RLS, never expose to the client.
# The legacy service_role JWT also works.
SUPABASE_SECRET_KEY="sb_secret_REPLACE_ME"

# Access-code gate — REQUIRED. The single shared code that unlocks /login and
# /signup; without it the build fails. Minimum 8 characters; rotate by changing
# this value, which invalidates every gate cookie already issued.
ACCESS_CODE="REPLACE_ME_WITH_A_LONG_RANDOM_CODE"

# Calendar sync cron — REQUIRED, minimum 16 characters. Vercel Cron sends this
# as `Authorization: Bearer <value>` to GET /api/cron/calendar-sync, which is the
# only route reachable with no session and no access code — so this secret is the
# entire thing guarding it. Generate with: openssl rand -base64 32
CRON_SECRET="REPLACE_ME_WITH_A_LONG_RANDOM_SECRET"

# Inngest signing key — REQUIRED, minimum 32 characters. `/api/inngest` is
# exempt from the access-code gate and accepts POST/PUT, so this key is the only
# thing authenticating it: Inngest signs every invocation and the serve handler
# verifies the signature. Copy it from the Inngest dashboard -> Manage -> Signing
# key (format: signkey-prod-<64 hex>). `npx inngest-cli dev` ignores this value,
# but env.ts still requires it, so set it locally too.
INNGEST_SIGNING_KEY="signkey-prod-REPLACE_ME"

# Inngest dev mode — LOCAL ONLY. Set to 1 when running `npx inngest-cli dev`.
# ⚠ Required locally, and easy to miss: inngest v4 does NOT infer dev mode from
# NODE_ENV (v3 did). With this unset the SDK runs in cloud mode even under
# `next dev`, so it demands a valid signature and answers the dev server 401 on
# every GET/PUT — the app never syncs and no function ever runs.
# It MUST stay unset in production: setting it there disables signature
# verification on /api/inngest, which is the only thing authenticating that
# endpoint — an unsigned POST would then run job code against the database
# through the RLS-bypassing admin client. Two things enforce that: env.ts only
# accepts 0/1/true/false (the SDK would otherwise read a typo like `yes` as the
# URL `http://yes` and quietly enable dev mode), and src/inngest/client.ts throws
# at startup if dev mode is ever active with VERCEL_ENV=production.
INNGEST_DEV=1

# Inngest event key — optional. Authenticates US to Inngest when sending events;
# unset means events cannot be published in production, but nothing becomes
# reachable. The local dev server issues its own key and ignores this one.
# Inngest dashboard -> Manage -> Event keys
# INNGEST_EVENT_KEY="REPLACE_ME"

# AI provider keys — the two-provider core (PLAN.md §AI Strategy §1b). Both are optional:
# an unset key disables an AI feature, it never opens anything up. `packages/ai` never reads
# process.env — env.ts injects these into `createAIRuntime`.
#
# Anthropic: generation, coding, user-facing chat (claude-sonnet-5), high-stakes synthesis
# (claude-opus-4-8), cheap cross-family critic (claude-haiku-4-5).
# https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY="sk-ant-REPLACE_ME"

# Google Gemini: long-context/multimodal extraction (gemini-3.1-pro-preview) and the
# high-volume classification tier (gemini-3.1-flash-lite). Name must match exactly — the
# AI SDK's own convention. https://aistudio.google.com/apikey
# GOOGLE_GENERATIVE_AI_API_KEY="REPLACE_ME"

# Voyage AI — embeddings for pgvector retrieval (Wave 4; nothing calls it yet). Embeddings
# stay single-vendor on Voyage regardless of the LLM split: mixing embedding models breaks
# vector comparability. https://dashboard.voyageai.com/api-keys
# VOYAGE_API_KEY="pa-REPLACE_ME"

# AI kill switch and budget guard (PLAN.md §AI Strategy §6). All three are optional with
# the defaults shown; `packages/ai` never reads them directly — env.ts injects them into
# createAIRuntime, which is what makes them enforceable in exactly one place.

# The runaway-cost circuit breaker. `true` makes every metered call fail fast before a
# token is spent: background jobs stay queued (nothing is lost) and chat answers "AI
# features are paused". Flipping this in Vercel + redeploying stops all spend in minutes.
# Only 0/1/true/false are accepted — a typo fails the build rather than quietly leaving
# AI on (or, worse, quietly turning it off). Default: false.
AI_KILL_SWITCH=false

# Clamps every job's resolved model rank. `deep` is the top rank, so it means "no clamp,
# circuit breaker only" — the production value. Set `fast` to force every job down to
# Flash-Lite / Haiku and keep the app alive cheaply while investigating a spend spike.
# Default: deep.
AI_MAX_TIER=deep

# Soft monthly cap in USD, checked against the ai_daily_cost rollup before each call.
# Past 100% deep-rank background jobs defer; past 125% balanced ones too; past 150%
# (§4's ≈$110 hard threshold) it behaves as if AI_KILL_SWITCH were set. Interactive chat
# is the last thing to die. §4's planning range is $35–60/month. Default: 75.
AI_MONTHLY_BUDGET_USD=75

# OpenAI is deliberately NOT wired (§1b) — GPT-5.6 is squeezed between the two providers
# above on every axis, so a third SDK, caching model, price table and key buys little today.

# Auth emails via Resend (Supabase Send Email Hook) — production concern;
# optional locally. https://resend.com/api-keys
# RESEND_API_KEY="re_REPLACE_ME"
# Secret shown when creating the hook: Supabase -> Authentication -> Hooks -> Send Email
# SEND_EMAIL_HOOK_SECRET="v1,whsec_REPLACE_ME"
# Sender — must be on a Resend-verified domain (fallback: onboarding@resend.dev)
# EMAIL_FROM="Study Dashboard <auth@alexanderkrink.com>"
