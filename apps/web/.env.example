# Copy to .env.local and fill in real values (apps/web/.env.local).
# Values come from your Supabase dashboard: Project Settings -> API Keys.

# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"

# Publishable key (sb_publishable_...). The legacy anon JWT also works.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_REPLACE_ME"

# Secret key (sb_secret_...) — server-only, bypasses RLS, never expose to the client.
# The legacy service_role JWT also works.
SUPABASE_SECRET_KEY="sb_secret_REPLACE_ME"

# Anthropic API key — optional until AI features land (M1).
# https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY="sk-ant-REPLACE_ME"
