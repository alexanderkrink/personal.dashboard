{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": ["CI", "SKIP_ENV_VALIDATION"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NEXT_PUBLIC_*",
        "SUPABASE_*",
        "ACCESS_CODE",
        "ANTHROPIC_API_KEY",
        "CRON_SECRET",
        "INNGEST_SIGNING_KEY",
        "INNGEST_EVENT_KEY",
        "INNGEST_DEV",
        "VERCEL_ENV",
        "RESEND_API_KEY",
        "SEND_EMAIL_HOOK_SECRET",
        "EMAIL_FROM",
        "VERCEL",
        "VERCEL_*"
      ]
    },
    "typecheck": {},
    "test": {},
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
